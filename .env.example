# Copy to `.env` and fill in. Never commit `.env`.
# Used by collect_victim_embeddings.py and the training notebook for submission.

VICTIM_API_TOKEN=
VICTIM_SEED=
VICTIM_PORT=9025

# Host for /query (no port in URL; port is VICTIM_PORT)
VICTIM_QUERY_HOST=http://34.122.51.94

# Training notebook: directory containing out*.pickle from collection step
EMBEDDINGS_DIR=embeddings

# Path to public image tensor dataset
PUBLIC_DATASET_PATH=ModelStealingPub.pt

# Optional: full URL for ONNX submission endpoint
# VICTIM_SUBMIT_URL=http://34.122.51.94:9090/stealing
